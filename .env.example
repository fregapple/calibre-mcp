# ------------------------------------------------------------
# Calibre Docker Container Configuration
# ------------------------------------------------------------

# Name of the Docker container running Calibre
CALIBRE_CONTAINER_NAME=calibre
CALIBRE_LIBRARY_BASE_PATH=/data/calibre


# ------------------------------------------------------------
# API Keys for MCP Authentication
# ------------------------------------------------------------

# API key for Samuel's library
USER1_API_KEY=SUPERSECRETKEY

# API key for Wife's library
USER2_API_KEY=SUPERSECRETKEY2


# ------------------------------------------------------------
# Optional: Kindle Email Addresses
# ------------------------------------------------------------

# Used for future "send to Kindle" tools
USER1_KINDLE_EMAIL=user1@example.com
USER2_KINDLE_EMAIL=user2@example.com